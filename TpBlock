local function createCircle(character)
-- Clean up old parts
for _, p in ipairs(circleParts) do p:Destroy() end
circleParts = {}
local root = character:WaitForChild("HumanoidRootPart")
for i = 1, PartsCount do
local part = Instance.new("Part")
part.Anchored = true
part.CanCollide = false
part.Material = Enum.Material.Neon
part.Color = PART_COLOR
part.Transparency = 0.3
part.Size = Vector3.new(1, PART_HEIGHT, PART_THICKNESS) -- Size adjusted in RenderStep
part.Parent = workspace
table.insert(circleParts, part)
end
-- Disconnect old connection if it exists
RunService:UnbindFromRenderStep("CircleFollow")
RunService:BindToRenderStep("CircleFollow", Enum.RenderPriority.Camera.Value + 1, function()
if not character or not root.Parent then return end
for i, part in ipairs(circleParts) do
local a1 = math.rad((i - 1) / PartsCount * 360)
local a2 = math.rad(i / PartsCount * 360)
local p1 = Vector3.new(math.cos(a1), 0, math.sin(a1)) * CIRCLE_RADIUS
local p2 = Vector3.new(math.cos(a2), 0, math.sin(a2)) * CIRCLE_RADIUS
local center = (p1 + p2) / 2 + root.Position - Vector3.new(0, 2.5, 0) -- Adjusted to feet level
part.Size = Vector3.new((p2 - p1).Magnitude, PART_HEIGHT, PART_THICKNESS)
part.CFrame = CFrame.new(center, center + (p2 - p1)) * CFrame.Angles(0, math.pi / 2, 0)
end
end)
end
