local function safeLoadFromUrl(url)
    task.spawn(function()
        local ok, body = pcall(function()
            return game:HttpGet(url)
        end)
        if not ok or type(body) ~= "string" or #body == 0 then return end
        local fn, err = loadstring(body)
        if not fn then return end
        pcall(fn)
    end)
end

